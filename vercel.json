{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "functions": {
    "api/scripts/run.ts": {
      "maxDuration": 300,
      "includeFiles": "scraper/**,scripts/**,server/**"
    },
    "api/scripts/health.ts": {
      "maxDuration": 10
    }
  }
}
